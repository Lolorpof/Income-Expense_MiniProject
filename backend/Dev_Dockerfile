# no need to copy files from src cuz of volume mapping in compose file
FROM node:22-alpine 
WORKDIR /app
RUN apk add --no-cache curl dos2unix postgresql-client
RUN npm install -g pnpm
COPY package*.json .
COPY pnpm-lock.yaml .
RUN pnpm install --frozen-lockfile
EXPOSE 6900
COPY ./scripts ./scripts
RUN dos2unix ./scripts/dev_init.sh
RUN chmod +x ./scripts/dev_init.sh
ENTRYPOINT [ "./scripts/dev_init.sh" ]
CMD ["pnpm", "run", "start:dev"]